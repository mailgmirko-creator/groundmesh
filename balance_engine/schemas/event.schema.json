{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Event",
  "type": "object",
  "required": [
    "id",
    "type",
    "context",
    "timestamp"
  ],
  "properties": {
    "id": {
      "type": "string"
    },
    "actor_id": {
      "type": "string"
    },
    "type": {
      "type": "string",
      "enum": [
        "lie",
        "steal",
        "kill",
        "destroy",
        "truth",
        "stewardship",
        "care",
        "creation"
      ]
    },
    "context": {
      "type": "object"
    },
    "evidence": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "inner_signals": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "evidence_strength": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "ambiguity_level": {
      "oneOf": [
        {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        {
          "type": "string",
          "enum": [
            "low",
            "medium",
            "high"
          ]
        }
      ]
    },
    "reversibility": {
      "oneOf": [
        {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        {
          "type": "string",
          "enum": [
            "low",
            "medium",
            "high"
          ]
        }
      ]
    },
    "fatigue_load": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "layer_hint": {
      "type": "string",
      "enum": [
        "individual",
        "system",
        "planet"
      ]
    }
  },
  "additionalProperties": true
}
